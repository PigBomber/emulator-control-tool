# ============================================================
# fold-server 配置文件
# ============================================================
# 用法：
#   1. 复制本文件为 config.ini（同目录）：  cp config.ini.example config.ini
#   2. 改 config.ini 里的值，重启 fold-server.py 生效
#
# 优先级（高 → 低）：
#   命令行参数  >  环境变量  >  config.ini  >  代码默认值
#   即命令行传参最优先；环境变量其次；都没给时才用 config.ini。
#
# config.ini 是本机私有配置，已加入 .gitignore，不会被提交。
# 改了默认值想共享给团队？改本文件（config.ini.example）后提交。
# ============================================================

[emulator]
# 模拟器实例名（Emulator -list 列出的名字，如 Mate X7 / Pura X / MateBook Pro）
# 命令行：python3 fold-server.py "Pura X"
# 环境变量：EMULATOR_INSTANCE
instance = Mate X7

# 是否无窗口启动模拟器
#   false = 带 GUI 窗口（默认，可观察折叠动画/方向）
#   true  = 无窗口（省资源/CI）
# 环境变量：FOLD_HEADLESS（1=true，0=false）
headless = false

# 等待模拟器上线超时秒数（冷启动常见 30~90s，慢的话调大）
# 环境变量：FOLD_EMU_TIMEOUT
start_timeout = 120


[network]
# fold-server 监听端口（宿主机）
server_port = 8766

# 设备内访问端口（模拟器内 FoldTrigger 访问的端口，通过 rport 转发到 server_port）
# 用不同端口避免与 fold-server 监听冲突
device_port = 8765

# 多设备时显式指定目标设备的 connect-key（hdc list targets 的输出，如 127.0.0.1:5555）
# 留空 = 自动选择（单设备直用，多设备取第一个并警告）
# 环境变量：HDC_CONNECT_KEY
connect_key =


[paths]
# 以下留空 = 自动探测。只在自动探测失败时才需要手动指定。
# 环境变量：EMULATOR_PATH / HDC_PATH / DEVECO_SDK_HOME

# Emulator 可执行文件路径（留空自动探测）
emulator_path =

# hdc 可执行文件路径（留空自动探测）
hdc_path =
